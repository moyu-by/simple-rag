# ==========================================
# 开发环境配置示例
# 复制此文件为 application-dev.yml 并填入你自己的配置
# ==========================================

# RSA 密钥路径（默认从 classpath 加载）
env-key-path: classpath:key

# JWT 签名密钥（使用 openssl rand -hex 32 生成）
env-jwt:
  key: your-256-bit-hex-secret-key-here-change-it
  ttl: 604800000  # 7 天（毫秒）
