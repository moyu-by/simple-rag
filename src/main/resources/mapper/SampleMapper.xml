<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
 =====================================================
  样板 Mapper XML 文件
  使用 MyBatis-Plus 注解能满足大部分场景，不需要写 XML。
  只有以下情况才需要此文件：

    1. 复杂联表查询（多表 JOIN）
    2. 自定义 SQL 分页查询
    3. 批量操作优化
    4. 复杂的结果映射（resultMap）

  复制此文件并重命名为 EntityMapper.xml，修改 namespace 即可。
 =====================================================
-->
<mapper namespace="com.example.demo.mapper.SampleMapper">

    <!-- ==================== 基础结果映射 ==================== -->
    <resultMap id="BaseResultMap" type="com.example.demo.entity.SampleEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- ==================== 通用列 ==================== -->
    <sql id="BaseColumns">
        id, name, create_time, update_time
    </sql>

    <!-- ==================== 自定义分页查询 ====================
         用法: 在 Mapper 接口中定义
         IPage<SampleEntity> selectPageVo(IPage<?> page, @Param("name") String name);
    -->
    <select id="selectPageVo" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM sample_table
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- ==================== 联表查询 ====================
         用法:
         List<UserRoleVo> selectUserWithRole(@Param("userId") Long userId);
    -->
    <select id="selectUserWithRole" resultType="com.example.demo.entity.UserRoleVo">
        SELECT u.*, r.role_name
        FROM user u
        LEFT JOIN user_role ur ON u.id = ur.user_id
        LEFT JOIN role r ON ur.role_id = r.id
        WHERE u.id = #{userId}
    </select>

    <!-- ==================== 批量更新 ==================== -->
    <update id="batchUpdateStatus">
        UPDATE sample_table
        SET status = #{status}, update_time = NOW()
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
